FROM rust:1.94-bookworm AS builder

WORKDIR /workspace
COPY . .
RUN cargo build --release -p lexonfabric-indexer

FROM debian:bookworm-slim AS runtime

RUN apt-get update \
    && apt-get install -y --no-install-recommends bash ca-certificates coreutils findutils rsync \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
COPY --from=builder /workspace/target/release/lexonfabric-indexer /usr/local/bin/lexonfabric-indexer

ENTRYPOINT ["bash", "/workspace/scripts/lexonfabric-scale-test.sh"]
